{
  "manifest_version": 3,
  "name": "Instagram Reels Gesture Scroller",
  "version": "1.0.0",
  "description": "Control Instagram Reels scrolling with hand gestures via your webcam.",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://www.instagram.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/reels/*", "https://www.instagram.com/"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "externally_connectable": {
    "matches": [
     "https://instagram-gesture-scroller.vercel.app/" 
    ]
  }
}
